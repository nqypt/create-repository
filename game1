<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>ガチャゲーム</title>
<style>
    body {
        font-family: "Hiragino Kaku Gothic ProN", sans-serif;
        text-align: center;
        background: linear-gradient(135deg, #6dd5ed, #2193b0);
        color: white;
        margin: 0;
        padding: 20px;
    }

    h1 {
        margin-bottom: 10px;
    }

    #gachaBtn {
        padding: 15px 30px;
        font-size: 20px;
        border: none;
        border-radius: 10px;
        background-color: gold;
        color: black;
        cursor: pointer;
        box-shadow: 0 5px #999;
    }

    #gachaBtn:active {
        box-shadow: 0 2px #666;
        transform: translateY(3px);
    }

    #result {
        margin-top: 30px;
        font-size: 24px;
    }

    .card {
        margin-top: 20px;
        padding: 20px;
        border-radius: 15px;
        display: inline-block;
        min-width: 200px;
    }

    .N { background: #ccc; color: black; }
    .R { background: #4caf50; }
    .SR { background: #2196f3; }
    .SSR { background: linear-gradient(45deg, gold, orange); color: black; }

    .shine {
        animation: shine 1s ease-in-out infinite alternate;
    }

    @keyframes shine {
        from { filter: brightness(1); }
        to { filter: brightness(1.5); }
    }
</style>
</head>
<body>

<h1>🎲 ガチャゲーム</h1>
<p>ボタンを押してガチャを引こう！</p>

<button id="gachaBtn">ガチャを引く</button>

<div id="result"></div>

<script>
const characters = [
    { name: "スライム", rarity: "N", rate: 50 },
    { name: "ゴブリン", rarity: "N", rate: 25 },
    { name: "ナイト", rarity: "R", rate: 15 },
    { name: "魔法使い", rarity: "R", rate: 7 },
    { name: "ドラゴン", rarity: "SR", rate: 2.5 },
    { name: "天使", rarity: "SR", rate: 0.4 },
    { name: "神龍", rarity: "SSR", rate: 0.1 }
];

function drawGacha() {
    const rand = Math.random() * 100;
    let sum = 0;

    for (let char of characters) {
        sum += char.rate;
        if (rand <= sum) {
            return char;
        }
    }
}

document.getElementById("gachaBtn").addEventListener("click", () => {
    const result = drawGacha();
    const resultDiv = document.getElementById("result");

    resultDiv.innerHTML = `
        <div class="card ${result.rarity} ${result.rarity === 'SSR' ? 'shine' : ''}">
            <h2>${result.rarity}</h2>
            <p>${result.name}</p>
        </div>
    `;

    // SSR演出
    if (result.rarity === "SSR") {
        alert("✨ SSRキター！！ ✨");
    }
});
</script>

</body>
</html>
